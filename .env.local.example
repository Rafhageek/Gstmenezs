# ============================================================
# Painel MNZ — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para `.env.local` e preencha com as suas
# credenciais do Supabase. NÃO faça commit do `.env.local`.
#
# Onde encontrar no Supabase:
#   Dashboard > Project Settings > API
# ============================================================

# URL pública do projeto Supabase (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon) — pode ser exposta no client
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (service_role) — NUNCA expor no client
# Usada apenas em rotas de servidor / scripts administrativos
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Google Gemini (assistente IA do dashboard)
# ============================================================
# Obtenha em: https://aistudio.google.com/apikey
# Tier grátis: 15 req/min, 1M tokens/dia (modelo Flash)
# Deixe em branco para usar apenas o assistente local (regex).
GEMINI_API_KEY=
